# ============================================================
# VulnChain Environment Configuration
# Copy this file to .env and fill in all values
# Never commit .env to git
# ============================================================

# Flask secret key (required)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT secret key (required)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# NVD API key (optional but recommended for faster enrichment)
# Without key: 5 requests per 30 seconds
# With key:   50 requests per 30 seconds
# Get free key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Default user created on first Docker start (optional)
# If not set, use: docker exec -it vulnchain python create_user.py --username X --password Y
VULNCHAIN_USER=analyst
VULNCHAIN_PASSWORD=ChangeMe123
